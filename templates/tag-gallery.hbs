<div class="npc-tags-gallery-content">
  <div class="gallery-sidebar">
    <div class="search-section">
        <label><i class="fas fa-search"></i> Pesquisar por Tags</label>
        <p class="notes" style="font-size: 0.7rem;">Espaço ou Enter para criar etiquetas. Cada campo é um grupo (AND). O resultado final é a união dos grupos (OR).</p>
        
        <div class="search-groups">
            {{#each groups}}
            <div class="search-group-container">
                <div class="search-group-pills">
                    {{#each this.tags}}
                    <span class="search-tag-pill">
                        {{this}}
                        <i class="fas fa-times remove-search-tag" data-group-index="{{../this.index}}" data-tag="{{this}}"></i>
                    </span>
                    {{/each}}
                    <input type="text" class="search-input" data-index="{{this.index}}" placeholder="{{#unless this.tags}}ex: forte careca{{/unless}}" />
                </div>
                {{#if (gt ../groups.length 1)}}
                <button type="button" class="remove-group-btn absolute" data-index="{{this.index}}" title="Remover Grupo">&times;</button>
                {{/if}}
            </div>
            {{/each}}
        </div>

        <button type="button" class="add-group-btn">
            <i class="fas fa-plus"></i> Novo Grupo de Busca
        </button>
    </div>
    
    <div class="gallery-stats">
        <span>Encontrados: <strong>{{actors.length}}</strong> atores</span>
    </div>
  </div>

  <div class="gallery-main">
    <div class="actors-grid">
      {{#each actors}}
      <div class="actor-card" data-actor-id="{{this.id}}" title="{{this.name}}">
        <div class="actor-image" style="background-image: url('{{this.img}}');"></div>
        <div class="actor-info">
          <span class="actor-name">{{this.name}}</span>
        </div>
      </div>
      {{/each}}
      
      {{#unless actors}}
      <div class="no-results">
        <i class="fas fa-ghost"></i>
        <p>Nenhum ator encontrado com estas tags.</p>
      </div>
      {{/unless}}
    </div>
  </div>
</div>
